pipeline {
    agent any

    environment {
        AWS_REGION = "ap-south-1"
        ECR_REPO = "924263791418.dkr.ecr.ap-south-1.amazonaws.com/epc-frontend"
        IMAGE_TAG = "${BUILD_NUMBER}"
        FRONTEND_SERVER = "13.207.57.145"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('epc-frontend-main') {
                    sh 'npm install'
                }
            }
        }

        stage('Build Application') {
            steps {
                dir('epc-frontend-main') {
                    sh 'npm run build'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('epc-frontend-main') {
                    sh '''
                    docker build --no-cache -t epc-frontend:${IMAGE_TAG} .
                    '''
                }
            }
        }

        stage('Login to ECR') {
            steps {
                sh '''
                aws ecr get-login-password --region ${AWS_REGION} | \
                docker login --username AWS --password-stdin 924263791418.dkr.ecr.ap-south-1.amazonaws.com
                '''
            }
        }

        stage('Tag Image') {
            steps {
                sh '''
                docker tag epc-frontend:${IMAGE_TAG} ${ECR_REPO}:${IMAGE_TAG}
                '''
            }
        }

        stage('Push Image to ECR') {
            steps {
                sh '''
                docker push ${ECR_REPO}:${IMAGE_TAG}
                '''
            }
        }

        stage('Deploy to Frontend UAT') {
            steps {
                sshagent(credentials: ['frontend-key']) {
                    sh """
                    ssh -o StrictHostKeyChecking=no ubuntu@${FRONTEND_SERVER} '
                    aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin 924263791418.dkr.ecr.ap-south-1.amazonaws.com

                    docker pull ${ECR_REPO}:${IMAGE_TAG}

                    docker stop epc-frontend || true
                    docker rm epc-frontend || true

                    docker run -d \
                      --name epc-frontend \
                      -p 80:80 \
                      --restart unless-stopped \
                      ${ECR_REPO}:${IMAGE_TAG}
                    '
                    """
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully.'
        }

        failure {
            echo 'Pipeline execution failed.'
        }
    }
}
